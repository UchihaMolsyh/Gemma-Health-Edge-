# Gemma Health Edge — Backend Environment Variables
# Copy this to .env and fill in your values.

GHE_HOST=0.0.0.0
GHE_PORT=8000
GHE_BACKEND_URL=http://127.0.0.1:8080
GHE_STATIC_DIR=../frontend/pc
GHE_GOOGLE_API_KEY=
GHE_OPENROUTER_API_KEY=
GHE_LOG_LEVEL=INFO
GHE_DEBUG=false
GHE_RATE_LIMIT=30/minute
GHE_CACHE_TTL=3600
GHE_CACHE_MAX_SIZE=200
